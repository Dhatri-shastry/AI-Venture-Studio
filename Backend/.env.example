PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-venture-studio

# LLM Providers (at least one required; GEMINI is the default)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

DEFAULT_LLM_PROVIDER=gemini

# Automatic fallback: if the requested provider fails for any reason
# (quota exhausted, overloaded, missing/expired key), the router tries
# the next one in this list automatically - no code changes needed.
# Only providers with an API key actually set above will be attempted;
# add GROQ_API_KEY (Groq's free tier is generous) so Gemini running out
# of quota doesn't take your app down with it.
LLM_FALLBACK_ORDER=gemini,groq,openrouter

# RAG / Vector store (Chroma) - run locally with:
#   pip install chromadb && chroma run --path ./chroma-data
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=venture_docs

# Optional: web_search tool (src/tools/search.tool.ts) - general web
# results (news, funding, trends, industry context)
TAVILY_API_KEY=

# Optional but recommended: real local business data (src/tools/places.tool.ts)
# - this is what actually answers "how many competitors are near me"
# style questions. General web search (Tavily above) genuinely can't do
# this well; it crawls articles, not structured business directories.
#
# Setup: Google Cloud Console -> create/select a project -> enable
# "Places API" -> Credentials -> Create API Key. Check Google's current
# Places API pricing page before enabling billing - there's a monthly
# free credit, but confirm the current terms yourself since pricing
# changes over time.
GOOGLE_PLACES_API_KEY=
